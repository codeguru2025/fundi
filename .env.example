# Lumina — Environment Variables
# Copy this file to .env and fill in your values.
# In production (DO App Platform), set these in the DigitalOcean UI → Environment Variables.
# Mark sensitive values as Encrypted in the DO console.

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# Your public URL — used for OAuth callback, CORS, and session cookies
# On DO App Platform: https://your-app-name.ondigitalocean.app
# On custom domain:   https://your-domain.com
APP_URL=https://fundi-46s3y.ondigitalocean.app

# ─── Database ─────────────────────────────────────────────────────────────────
# Use the POOLED connection string from Supabase (port 6543, pgBouncer session mode)
# Dashboard: Supabase → Project → Settings → Database → Connection Pooling
DATABASE_URL=postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# For running migrations only, use the DIRECT connection (port 5432)
# DATABASE_DIRECT_URL=postgres://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ─── Sessions ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# ENCRYPT THIS in the DO console — never commit to git
SESSION_SECRET=replace-with-64-char-random-secret

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Admin ────────────────────────────────────────────────────────────────────
# The first Google login with this email will be granted admin access
DEFAULT_ADMIN_EMAIL=your-admin@email.com

# ─── DigitalOcean Spaces (replaces Replit Object Storage) ─────────────────────
# DO Console → Spaces → Create Space → API Keys
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=lumina-content
# Region where your Spaces bucket is created (e.g. ams3, nyc3, sgp1, fra1)
DO_SPACES_REGION=ams3

# ─── Payments (Paynow) ────────────────────────────────────────────────────────
# ENCRYPT these in the DO console
PAYNOW_INTEGRATION_ID=
PAYNOW_INTEGRATION_KEY=

# ─── Logging ──────────────────────────────────────────────────────────────────
# info | warn | error | debug
LOG_LEVEL=info
